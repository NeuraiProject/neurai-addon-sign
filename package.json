{
  "name": "neurai-wallet-extension",
  "version": "0.12.0",
  "description": "Neurai Sign (XNA) Chrome Extension - Manage wallet, sign messages, check balance",
  "private": true,
  "scripts": {
    "postinstall": "node sync-libs.js",
    "dev": "vite --config vite.config.test.js",
    "build": "node build-all.js",
    "build:ext": "node build-ext.js",
    "build:test": "vite build --config vite.config.test.js",
    "sync-libs": "node sync-libs.js",
    "pack": "node build-ext.js && node pack.js",
    "typecheck": "tsc --noEmit",
    "verify:no-rpc-sign": "if grep -rn 'signrawtransaction' src/; then echo 'ERROR: forbidden RPC signing path present'; exit 1; fi"
  },
  "dependencies": {
    "@neuraiproject/neurai-assets": "^1.2.5",
    "@neuraiproject/neurai-create-transaction": "^0.3.0",
    "@neuraiproject/neurai-key": "^4.0.0",
    "@neuraiproject/neurai-message": "^0.9.1",
    "@neuraiproject/neurai-reader": "^0.0.9",
    "@neuraiproject/neurai-scripts": "^0.5.0",
    "@neuraiproject/neurai-sign-esp32": "^0.4.0",
    "@neuraiproject/neurai-sign-transaction": "^2.1.0"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.38",
    "typescript": "^6.0.2",
    "vite": "^6.4.2"
  }
}
